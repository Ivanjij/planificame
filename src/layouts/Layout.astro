---
import Nav from "../components/Nav.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="png" href="/favicon.jpeg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      body {
        background-color: #eff6ff; /* bg-blue-50 */
        margin: 0;
        font-family: Arial, sans-serif;
      }

      .container {
        max-width: 1200px; /* Equivalente a container */
        margin: 0 auto; /* Equivalente a mx-auto */
        padding: 0 1rem; /* Añade un padding para dispositivos pequeños */
      }
    </style>
  </head>
  <body>
    <Nav />
    <div class="container">
      <slot />
    </div>
  </body>
</html>