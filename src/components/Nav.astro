<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mi Sitio Web Profesional</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    /* Variables CSS para colores y tipografía */
    :root {
      --sidebar-width-expanded: 250px; /* Ancho del Sidebar expandido */
      --sidebar-width-collapsed: 70px; /* Ancho del sidebar colapsado */
      --sidebar-bg-color: #343a40; /* Gris oscuro para el fondo del sidebar/offcanvas */
      --sidebar-text-color: #f8f9fa; /* Blanco suave para el texto */
      --sidebar-hover-color: #adb5bd; /* Gris más claro para el hover */
      --navbar-top-height: 56px; /* Altura de la barra superior */
      --navbar-top-bg-color: var(--sidebar-bg-color); /* MISMO COLOR QUE EL SIDEBAR */
      --brand-font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Ajuste para el espacio del navbar superior fijo */
    body {
      padding-top: var(--navbar-top-height); /* Deja espacio para el navbar superior */
      transition: padding-left 0.3s ease; /* Transición suave para el padding al colapsar */
      overflow-x: hidden; /* Previene el scroll horizontal en todo el cuerpo */
    }

    /* ---------------------------------------------------- */
    /* Estilos para la BARRA SUPERIOR */
    /* ---------------------------------------------------- */
    .header-navbar {
      background-color: var(--navbar-top-bg-color) !important;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
      z-index: 1030; /* Menor que el sidebar en escritorio para que sobresalga */
      left: 0;
      right: 0;
      height: var(--navbar-top-height);
      transition: left 0.3s ease; /* Transición para el 'left' al colapsar */
      display: flex; /* Asegura el uso de flexbox */
      align-items: center; /* Centra verticalmente el contenido */
      padding-left: 1rem; /* Espacio a la izquierda para el botón de menú en móvil */
      padding-right: 1rem; /* Espacio a la derecha para el texto */
    }
    
    /* El texto en la navbar superior */
    .header-navbar .navbar-text {
      color: var(--sidebar-text-color);
      font-weight: bold;
      font-size: 1.1rem;
      letter-spacing: 0.03em;
    }

    /* ---------------------------------------------------- */
    /* Estilos del botón de hamburguesa para el Offcanvas (Móvil) */
    /* ---------------------------------------------------- */
    .mobile-toggler-btn {
      color: var(--sidebar-text-color); /* Color del icono */
      font-size: 1.5rem;
      background: transparent;
      border: none;
      cursor: pointer;
      line-height: 1;
      margin-right: 1rem; /* Espacio entre el botón y el borde de la navbar */
    }

    /* ---------------------------------------------------- */
    /* Estilos para el OFFCANVAS (MENÚ LATERAL) */
    /* ---------------------------------------------------- */
    .offcanvas {
      background-color: var(--sidebar-bg-color) !important;
      color: var(--sidebar-text-color);
      width: var(--sidebar-width-expanded); /* Ancho por defecto (expandido) */
      transition: width 0.3s ease; /* Transición suave para el ancho */
      z-index: 1040; /* Mayor que la navbar superior para que sobresalga */
      /* No overflow-y: hidden here for mobile, as we want scroll for offcanvas if content overflows */
    }

    /* **NEW**: Force no vertical scroll when offcanvas is open (mobile) */
    .offcanvas.show {
        overflow-y: hidden;
    }


    .offcanvas-header {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding: 1rem;
      display: flex;
      align-items: center;
      justify-content: flex-start; /* Alinea los elementos al inicio por defecto */
      position: relative; /* Necesario para posicionar el botón de toggle con 'absolute' */
    }

    /* Estilo del logo/título en el Offcanvas (now just an icon) */
    .offcanvas-title .navbar-brand {
      color: var(--sidebar-text-color) !important;
      font-weight: bold;
      letter-spacing: 0.05em;
      font-size: 1.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: flex; /* Para alinear el icono del logo con el texto */
      align-items: center;
      transition: opacity 0.3s ease, width 0.3s ease; /* Transición para el colapsado */
    }
    .offcanvas-title .navbar-brand i { /* Estilo del icono del logo */
        font-size: 1.3em;
        margin-right: 0.5rem;
    }
    /* Hide brand text entirely if it's no longer needed */
    .offcanvas-title .navbar-brand .brand-text {
        display: none;
    }


    .btn-close {
      filter: invert(1);
      opacity: 0.8;
      transition: opacity 0.3s ease;
    }
    .btn-close:hover {
        opacity: 1;
    }

    .offcanvas-body {
      padding-top: 1rem;
      display: flex;
      flex-direction: column;
      overflow-x: hidden; /* Oculta el scroll horizontal si el texto se desborda */
      overflow-y: auto; /* Allow scroll for offcanvas-body if items exceed height (mobile) */
    }

    .offcanvas-body .nav-link {
      color: var(--sidebar-text-color) !important;
      transition: all 0.3s ease;
      padding: 0.75rem 1rem;
      border-radius: 0.25rem;
      display: flex;
      align-items: center;
      margin-bottom: 0.25rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      position: relative;
    }

    .offcanvas-body .nav-link i {
      font-size: 1.2em;
      margin-right: 1rem;
      flex-shrink: 0;
      /* NEW: Ensure icon stays in place on expand */
      transition: margin-right 0.3s ease;  
    }

    .offcanvas-body .nav-link span {
        flex-grow: 1;
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .offcanvas-body .nav-link:hover {
      color: var(--sidebar-hover-color) !important;
      background-color: rgba(255, 255, 255, 0.1);
      transform: translateX(5px);
    }

    .offcanvas-body .nav-link.active {
      font-weight: bold;
      color: white !important;
      background-color: rgba(255, 255, 255, 0.15);
    }

    /* Estilos del dropdown dentro del Offcanvas */
    .offcanvas-body .dropdown-menu {
        background-color: rgba(0, 0, 0, 0.3);
        border: none;
        box-shadow: none;
        position: static !important;
        transform: none !important;
        width: 100%;
        padding: 0.5rem 0;
        margin-top: 0;
        margin-bottom: 0.5rem;
    }

    .offcanvas-body .dropdown-item {
        color: var(--sidebar-text-color);
        padding: 0.75rem 1.5rem;
        font-size: 0.95rem;
        transition: background-color 0.2s ease, color 0.2s ease;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .offcanvas-body .dropdown-item:hover, .offcanvas-body .dropdown-item:focus {
        background-color: rgba(255, 255, 255, 0.08);
        color: var(--sidebar-hover-color);
    }

    .offcanvas-body .dropdown-divider {
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .offcanvas-footer-content {
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      text-align: center;
      font-size: 0.8rem;
    }

    /* Botón de colapsar sidebar (solo visible en escritorio) */
    .sidebar-toggle-btn {
        background: transparent;
        border: none;
        color: var(--sidebar-text-color);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 1;
        flex-shrink: 0; /* Evita que el botón se encoja */
        transition: color 0.3s ease;
        position: absolute; /* Allows for precise placement */
        right: 1rem; /* Aligns to the right of the header */
    }
    .sidebar-toggle-btn:hover {
        color: var(--sidebar-hover-color);
    }

    /* ---------------------------------------------------- */
    /* MEDIAS QUERIES para el MODO ESCRITORIO (>= Large - 992px) */
    /* ---------------------------------------------------- */
    @media (min-width: 992px) {
      /* Ajuste del padding del body para dejar espacio al sidebar fijo */
      body {
        padding-top: var(--navbar-top-height); /* Espacio para la navbar superior */
        /* Start with collapsed padding-left */
        padding-left: var(--sidebar-width-collapsed); /* Set initial state to collapsed */
      }

      /* La navbar superior empieza después del sidebar */
      .header-navbar {
        left: var(--sidebar-width-collapsed); /* Start with collapsed position */
      }

      /* Oculta el botón de hamburguesa móvil */
      .mobile-toggler-btn {
        display: none !important;
      }

      /* Transforma el Offcanvas en un Sidebar fijo */
      .offcanvas-start {
        transform: translateX(0%) !important;
        visibility: visible !important;
        position: fixed !important;
        top: 0; /* Empieza desde arriba */
        left: 0;
        height: 100vh; /* Ocupa toda la altura de la ventana */
        /* Start with collapsed width */
        width: var(--sidebar-width-collapsed); /* Set initial state to collapsed */
        border-right: 1px solid rgba(0, 0, 0, 0.1);
        box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
        z-index: 1040; /* Asegura que sobresalga de la navbar superior */
        transition: width 0.3s ease, transform 0.3s ease; /* Transición suave para el colapsado */
        flex-shrink: 0;
        overflow-y: hidden; /* **Importante**: Oculta el scroll vertical en desktop */
      }
      
      /* Oculta el botón de cerrar en el sidebar fijo de escritorio */
      .offcanvas-header .btn-close {
        display: none !important;
      }
      
      /* Asegura que el logo del Offcanvas se muestre */
      .offcanvas-header .offcanvas-title {
        display: flex; /* Usamos flexbox para alinear el logo y el botón de toggle */
        align-items: center;
        /* NEW: In desktop, the brand title is only the icon. So it should be centered when sidebar is collapsed */
        justify-content: center; /* Center the icon */
        margin-right: 0; /* Remove extra margin */
      }
      /* Hide the brand text entirely on desktop */
      .offcanvas-title .navbar-brand .brand-text {
        display: none;
      }


      /* Contenedor principal del contenido de la página */
      main.container {
        max-width: none;
        padding-left: 1rem;
        margin-left: 0;
      }

      /* ---------------------------------------------------- */
      /* Estilos para el SIDEBAR COLAPSADO (Modo Escritorio) */
      /* ---------------------------------------------------- */
      body.sidebar-collapsed {
        padding-left: var(--sidebar-width-collapsed); /* Ajusta padding del body */
      }

      body.sidebar-collapsed .header-navbar {
        left: var(--sidebar-width-collapsed); /* Ajusta la posición de la navbar superior */
      }
      
      body.sidebar-collapsed .offcanvas-start {
        width: var(--sidebar-width-collapsed); /* Ancho del sidebar colapsado */
      }

      /* Oculta el texto de los enlaces cuando el sidebar está colapsado */
      body.sidebar-collapsed .offcanvas-body .nav-link span {
          opacity: 0;
          width: 0;
          overflow: hidden; /* Asegura que el texto oculto no ocupe espacio */
      }

      /* Oculta el texto del logo del Offcanvas cuando el sidebar está colapsado */
      /* This is already handled by display: none for brand-text in desktop */
      /* body.sidebar-collapsed .offcanvas-title .navbar-brand span {
          opacity: 0;
          width: 0;
          overflow: hidden;
      } */
      
      /* Centra los iconos cuando el texto se oculta */
      body.sidebar-collapsed .offcanvas-body .nav-link {
          justify-content: center;
          padding: 0.75rem 0.5rem; /* Ajusta padding para que los iconos se vean bien */
      }
      body.sidebar-collapsed .offcanvas-body .nav-link i {
          margin-right: 0; /* Align icons when text is hidden */
      }

      /* Ajuste para el logo en modo colapsado */
      body.sidebar-collapsed .offcanvas-header .offcanvas-title .navbar-brand {
        justify-content: center; /* Centra el icono del logo */
        margin-right: 0; /* Elimina margen extra */
      }
      body.sidebar-collapsed .offcanvas-header .offcanvas-title .navbar-brand i {
        margin-right: 0; /* Elimina el margen a la derecha del icono del logo */
      }
      
      /* Asegurarse de que el botón de toggle del sidebar se mantenga visible y a la derecha en el header */
      .sidebar-toggle-btn {
          position: static; /* Remove absolute positioning on desktop */
          margin-left: auto; /* Push the button to the right using flexbox */
          right: auto; /* Ensure no absolute right property interferes */
          transition: color 0.3s ease; /* Keep the transition for hover */
      }
      
      /* Cuando el sidebar está colapsado, el botón de toggle debe alinearse al final */
      body.sidebar-collapsed .offcanvas-header {
        justify-content: flex-end; /* Alinea los elementos al final */
        padding-right: 1rem; /* Add some padding to the right for balance */
      }

      /* Adjust dropdowns in collapsed state for better visual */
      body.sidebar-collapsed .offcanvas-body .dropdown-menu {
          display: none; /* Hide dropdown content when sidebar is collapsed */
      }

      /* Styles for EXPANDED sidebar on desktop */
      body:not(.sidebar-collapsed) {
        padding-left: var(--sidebar-width-expanded);
      }
      body:not(.sidebar-collapsed) .header-navbar {
        left: var(--sidebar-width-expanded);
      }
      body:not(.sidebar-collapsed) .offcanvas-start {
        width: var(--sidebar-width-expanded);
      }
      
      /* When not collapsed, show the text elements */
      body:not(.sidebar-collapsed) .offcanvas-body .nav-link i {
          margin-right: 1rem; /* Restore margin to slide icon left */
      }
      body:not(.sidebar-collapsed) .offcanvas-body .nav-link span {
        opacity: 1; /* Show nav link text when expanded */
        width: auto; /* Allow nav link text to take its natural width */
        overflow: visible;
      }
      /* Ensure the brand icon is still centered when expanded on desktop,
          as there's no text beside it anymore */
      body:not(.sidebar-collapsed) .offcanvas-header .offcanvas-title .navbar-brand {
        justify-content: center;
        margin-right: 0;
      }

      /* Adjust offcanvas-header to use flexbox for alignment when expanded */
      body:not(.sidebar-collapsed) .offcanvas-header {
          justify-content: space-between; /* Distribute space between logo and toggle */
      }
    }

    /* Styles specifically for the offcanvas being shown (mobile) */
    .offcanvas.show .offcanvas-body {
        overflow-y: hidden; /* **NEW**: Remove vertical scroll when offcanvas is active on mobile */
    }

  </style>

</head>
<body>

  <nav class="navbar navbar-expand-lg navbar-dark fixed-top header-navbar">
    <button class="mobile-toggler-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
      <i class="bi bi-list"></i> </button>

    <span class="navbar-text ms-auto">
      <button class="btn btn-light" onclick="window.location.href = '/';"><i class="bi bi-box-arrow-left"></i>&nbsp; Salir</button>
    </span>
  </nav>

  <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
    <div class="offcanvas-header">
      <a class="navbar-brand offcanvas-title" href="/">
        <i class="bi bi-hexagon-fill">PLANIFICAME</i>
      </a>

      <button class="sidebar-toggle-btn d-none d-lg-block" id="sidebarToggle">
        <i class="bi bi-list"></i>
      </button>
      <button type="button" class="btn-close text-reset d-lg-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
      <ul class="navbar-nav justify-content-start flex-grow-1 pe-3">
        <li class="nav-item">
          <a class="nav-link" aria-current="page" href="/home">
            <i class="bi bi-house-door-fill"></i> <span>Inicio</span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/chat">
            <i class="bi bi-terminal-fill"></i> <span>ChatBot</span>
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/usuario">
            <i class="bi bi-person-fill"></i> <span>Cuenta</span>
          </a>
        </li>
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-three-dots"></i> <span>Más Opciones</span>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/faq">Preguntas Frecuentes</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/privacy">Política de Privacidad</a></li>
          </ul>
        </li>
      </ul>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sidebarToggle = document.getElementById('sidebarToggle');
      const body = document.body;
      const offcanvasNavbar = document.getElementById('offcanvasNavbar');

      // Function to toggle the collapsed state of the sidebar
      function toggleSidebar() {
        body.classList.toggle('sidebar-collapsed');
      }

      // Add event listener to the sidebar toggle button
      if (sidebarToggle) {
        sidebarToggle.addEventListener('click', toggleSidebar);
      }

      // Set initial state for desktop on page load
      if (window.innerWidth >= 992) {
          body.classList.add('sidebar-collapsed'); // Start desktop in collapsed mode
      }

      // Handle window resize to ensure correct state on desktop
      window.addEventListener('resize', function() {
        if (window.innerWidth < 992) {
          // If it's mobile, ensure the sidebar is not collapsed
          body.classList.remove('sidebar-collapsed');
        } else {
          // On desktop, ensure it's in the initial collapsed state if not already
          if (!body.classList.contains('sidebar-collapsed')) {
            body.classList.add('sidebar-collapsed');
          }
        }
      });

      // **NEW**: Control scroll behavior when offcanvas is shown/hidden (mobile)
      offcanvasNavbar.addEventListener('show.bs.offcanvas', function () {
          document.body.style.overflow = 'hidden'; // Prevent main page scroll when offcanvas is open
      });
      offcanvasNavbar.addEventListener('hide.bs.offcanvas', function () {
          document.body.style.overflow = ''; // Restore main page scroll when offcanvas is closed
      });
    });
  </script>

</body>
</html>